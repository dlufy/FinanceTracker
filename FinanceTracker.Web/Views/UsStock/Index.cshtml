@model FinanceTracker.Web.Models.ViewModels.UsStockViewModel
@{
    ViewData["Title"] = "US Stocks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🇺🇸 US Stock Holdings</h2>
    <div class="d-flex gap-2">
        @if (Model.CurrentUsdInrRate > 0)
        {
            <span class="badge bg-secondary fs-6 align-self-center">$1 = ₹@Model.CurrentUsdInrRate.ToString("N2")</span>
        }
        @if (Model.Holdings.Any())
        {
            <form asp-action="RefreshPrices" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary btn-sm">🔄 Refresh Prices</button>
            </form>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Add Stock Form -->
<div class="card shadow mb-4">
    <div class="card-header"><strong>➕ Add US Stock Holding</strong></div>
    <div class="card-body">
        <form asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <div class="row align-items-end g-3">
                <div class="col-md-2">
                    <label class="form-label">Symbol <span class="text-danger">*</span></label>
                    <input type="text" name="Symbol" value="@Model.Symbol" class="form-control text-uppercase"
                           placeholder="MSFT, AAPL..." required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Company Name</label>
                    <input type="text" name="CompanyName" value="@Model.CompanyName" class="form-control"
                           placeholder="Optional (e.g., Microsoft)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Quantity <span class="text-danger">*</span></label>
                    <input type="number" name="Quantity" value="@(Model.Quantity > 0 ? Model.Quantity.ToString() : "")"
                           class="form-control" step="0.0001" min="0.0001" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Avg Buy Price (USD) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" name="AverageBuyPriceUsd"
                               value="@(Model.AverageBuyPriceUsd > 0 ? Model.AverageBuyPriceUsd.ToString() : "")"
                               class="form-control" step="0.01" min="0.01" required />
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Add Stock</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Holdings.Any())
{
    <div class="row mb-4">
        <!-- Pie Chart -->
        <div class="col-md-4">
            <div class="card shadow h-100">
                <div class="card-header"><strong>Allocation by Stock (INR)</strong></div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="usStockPieChart" style="max-height:250px;"></canvas>
                </div>
            </div>
        </div>
        <!-- Summary -->
        <div class="col-md-8">
            <div class="row g-3">
                <div class="col-6">
                    <div class="card text-white bg-primary shadow">
                        <div class="card-body text-center">
                            <h6>Total Invested (INR)</h6>
                            <h4>₹ @Model.Holdings.Sum(h => h.InvestedValueInr).ToString("N2")</h4>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card text-white bg-info shadow">
                        <div class="card-body text-center">
                            <h6>Current Value (INR)</h6>
                            <h4>₹ @Model.Holdings.Sum(h => h.CurrentValueInr).ToString("N2")</h4>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card text-white bg-success shadow">
                        <div class="card-body text-center">
                            <h6>Invested (USD)</h6>
                            <h4>$ @Model.Holdings.Sum(h => h.InvestedValueUsd).ToString("N2")</h4>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    @{
                        var totalPL = Model.Holdings.Sum(h => h.ProfitLossInr);
                    }
                    <div class="card text-white @(totalPL >= 0 ? "bg-success" : "bg-danger") shadow">
                        <div class="card-body text-center">
                            <h6>P&amp;L (INR)</h6>
                            <h4>₹ @totalPL.ToString("N2")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Holdings Table -->
<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Holdings (@Model.Holdings.Count)</strong>
        @if (Model.Holdings.Any())
        {
            <form asp-action="DeleteAll" method="post" class="d-inline"
                  onsubmit="return confirm('Clear all US stock holdings?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger">Clear All</button>
            </form>
        }
    </div>
    <div class="card-body p-0">
        @if (Model.Holdings.Any())
        {
            <div class="p-2 border-bottom">
                <input type="text" id="usStockSearch" class="form-control form-control-sm"
                       placeholder="🔍 Filter by symbol or company..." />
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 sortable-table" id="usStockTable">
                    <thead class="table-dark">
                        <tr>
                            <th class="sortable" data-col="0">Symbol ↕</th>
                            <th class="sortable" data-col="1">Company ↕</th>
                            <th class="sortable text-end" data-col="2">Qty ↕</th>
                            <th class="sortable text-end" data-col="3">Avg (USD) ↕</th>
                            <th class="sortable text-end" data-col="4">Current (USD) ↕</th>
                            <th class="sortable text-end" data-col="5">Invested (INR) ↕</th>
                            <th class="sortable text-end" data-col="6">Current (INR) ↕</th>
                            <th class="sortable text-end" data-col="7">P&amp;L (INR) ↕</th>
                            <th class="sortable text-end" data-col="8">P&amp;L % ↕</th>
                            <th>Rate</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model.Holdings)
                        {
                            <tr>
                                <td><strong>@h.Symbol</strong></td>
                                <td>@h.CompanyName</td>
                                <td class="text-end">@h.Quantity.ToString("N4")</td>
                                <td class="text-end">$@h.AverageBuyPriceUsd.ToString("N2")</td>
                                <td class="text-end">$@h.CurrentPriceUsd.ToString("N2")</td>
                                <td class="text-end">₹@h.InvestedValueInr.ToString("N2")</td>
                                <td class="text-end">₹@h.CurrentValueInr.ToString("N2")</td>
                                <td class="text-end @(h.ProfitLossInr >= 0 ? "text-success" : "text-danger")">
                                    ₹@h.ProfitLossInr.ToString("N2")
                                </td>
                                <td class="text-end @(h.ProfitLossPercent >= 0 ? "text-success" : "text-danger")">
                                    @h.ProfitLossPercent.ToString("N2")%
                                </td>
                                <td><small class="text-muted">₹@h.ExchangeRateUsdInr.ToString("N2")</small></td>
                                <td>
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this holding?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@h.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="5" class="text-end"><strong>Total</strong></td>
                            <td class="text-end"><strong>₹@Model.Holdings.Sum(h => h.InvestedValueInr).ToString("N2")</strong></td>
                            <td class="text-end"><strong>₹@Model.Holdings.Sum(h => h.CurrentValueInr).ToString("N2")</strong></td>
                            <td class="text-end @(Model.Holdings.Sum(h => h.ProfitLossInr) >= 0 ? "text-success" : "text-danger")">
                                <strong>₹@Model.Holdings.Sum(h => h.ProfitLossInr).ToString("N2")</strong>
                            </td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted p-4">
                <p>No US stock holdings yet. Add one using the form above.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
// Pie chart
@if (Model.Holdings.Any())
{
    var labels = string.Join(",", Model.Holdings.Select(h => $"'{h.Symbol}'"));
    var values = string.Join(",", Model.Holdings.Select(h => h.CurrentValueInr.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)));
    <text>
    new Chart(document.getElementById('usStockPieChart'), {
        type: 'doughnut',
        data: {
            labels: [@Html.Raw(labels)],
            datasets: [{ data: [@Html.Raw(values)], backgroundColor: ['#4e73df','#1cc88a','#36b9cc','#f6c23e','#e74a3b','#858796','#5a5c69'] }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
    </text>
}

// Sort & Filter
setupSortFilter('usStockTable', 'usStockSearch');
</script>
}
