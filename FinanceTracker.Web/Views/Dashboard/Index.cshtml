@model FinanceTracker.Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 Portfolio Dashboard</h2>
    <form asp-controller="Dashboard" asp-action="RefreshPrices" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary">🔄 Refresh All Prices</button>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Summary Cards (clickable) -->
<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-2">
        <div class="card text-white bg-primary shadow h-100">
            <div class="card-body text-center">
                <h6 class="card-title">Total Invested</h6>
                <h4>₹ @Model.TotalInvested.ToString("N2")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-2">
        <div class="card text-white bg-info shadow h-100">
            <div class="card-body text-center">
                <h6 class="card-title">Current Value</h6>
                <h4>₹ @Model.TotalCurrentValue.ToString("N2")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-2">
        <div class="card text-white @(Model.TotalProfitLoss >= 0 ? "bg-success" : "bg-danger") shadow h-100">
            <div class="card-body text-center">
                <h6 class="card-title">Total P&amp;L</h6>
                <h4>₹ @Model.TotalProfitLoss.ToString("N2")</h4>
                <small>(@Model.TotalProfitLossPercent.ToString("N2")%)</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-2">
        <a asp-controller="Expense" asp-action="Index" class="text-decoration-none">
            <div class="card text-white bg-danger shadow h-100">
                <div class="card-body text-center">
                    <h6 class="card-title">Expenses (This Month)</h6>
                    <h4>₹ @Model.ExpensesThisMonth.ToString("N2")</h4>
                    <small>Total: ₹ @Model.TotalExpenses.ToString("N2")</small>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Category Breakdown Cards (clickable) -->
<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-2">
        <a asp-controller="Equity" asp-action="Index" class="text-decoration-none">
            <div class="card shadow h-100 border-primary">
                <div class="card-header bg-primary text-white"><strong>📈 Equities</strong></div>
                <div class="card-body">
                    <p class="mb-1">Invested: <strong>₹ @Model.EquityInvested.ToString("N2")</strong></p>
                    <p class="mb-1">Current: <strong>₹ @Model.EquityValue.ToString("N2")</strong></p>
                    <p class="mb-1 @(Model.EquityProfitLoss >= 0 ? "text-success" : "text-danger")">
                        P&amp;L: <strong>₹ @Model.EquityProfitLoss.ToString("N2")</strong>
                    </p>
                    <small class="text-muted">@Model.EquityPercent.ToString("N1")% of portfolio</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6 mb-2">
        <a asp-controller="MutualFund" asp-action="Index" class="text-decoration-none">
            <div class="card shadow h-100 border-success">
                <div class="card-header bg-success text-white"><strong>📋 Mutual Funds</strong></div>
                <div class="card-body">
                    <p class="mb-1">Invested: <strong>₹ @Model.MutualFundInvested.ToString("N2")</strong></p>
                    <p class="mb-1">Current: <strong>₹ @Model.MutualFundValue.ToString("N2")</strong></p>
                    <p class="mb-1 @(Model.MutualFundProfitLoss >= 0 ? "text-success" : "text-danger")">
                        P&amp;L: <strong>₹ @Model.MutualFundProfitLoss.ToString("N2")</strong>
                    </p>
                    <small class="text-muted">@Model.MutualFundPercent.ToString("N1")% of portfolio</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6 mb-2">
        <a asp-controller="UsStock" asp-action="Index" class="text-decoration-none">
            <div class="card shadow h-100 border-warning">
                <div class="card-header bg-warning text-dark"><strong>🇺🇸 US Stocks</strong></div>
                <div class="card-body">
                    <p class="mb-1">Invested: <strong>₹ @Model.UsStockInvested.ToString("N2")</strong></p>
                    <p class="mb-1">Current: <strong>₹ @Model.UsStockValue.ToString("N2")</strong></p>
                    <p class="mb-1 @(Model.UsStockProfitLoss >= 0 ? "text-success" : "text-danger")">
                        P&amp;L: <strong>₹ @Model.UsStockProfitLoss.ToString("N2")</strong>
                    </p>
                    <small class="text-muted">@Model.UsStockPercent.ToString("N1")% of portfolio</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6 mb-2">
        <a asp-controller="Cash" asp-action="Index" class="text-decoration-none">
            <div class="card shadow h-100 border-secondary">
                <div class="card-header bg-secondary text-white"><strong>🏦 Cash</strong></div>
                <div class="card-body">
                    <p class="mb-1">Balance: <strong>₹ @Model.CashValue.ToString("N2")</strong></p>
                    <small class="text-muted">@Model.CashPercent.ToString("N1")% of portfolio</small>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Charts Row -->
<div class="row mb-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header"><strong>Asset Allocation</strong></div>
            <div class="card-body">
                <canvas id="allocationChart" height="250"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header"><strong>Monthly Investment Trend</strong></div>
            <div class="card-body">
                <canvas id="monthlyChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Top Holdings -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between">
                <strong>Top Equities</strong>
                <a asp-controller="Equity" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.TopEquities.Any())
                {
                    <table class="table table-sm table-striped mb-0">
                        <thead><tr><th>Symbol</th><th class="text-end">Value</th><th class="text-end">P&L</th></tr></thead>
                        <tbody>
                            @foreach (var h in Model.TopEquities)
                            {
                                <tr>
                                    <td>@h.Symbol</td>
                                    <td class="text-end">₹@h.CurrentValue.ToString("N0")</td>
                                    <td class="text-end @(h.ProfitLoss >= 0 ? "text-success" : "text-danger")">
                                        ₹@h.ProfitLoss.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <p class="text-muted p-3">No equity holdings. <a asp-controller="Equity" asp-action="Index">Upload now</a></p> }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between">
                <strong>Top Mutual Funds</strong>
                <a asp-controller="MutualFund" asp-action="Index" class="btn btn-sm btn-outline-success">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.TopMutualFunds.Any())
                {
                    <table class="table table-sm table-striped mb-0">
                        <thead><tr><th>Scheme</th><th class="text-end">Value</th><th class="text-end">P&L</th></tr></thead>
                        <tbody>
                            @foreach (var h in Model.TopMutualFunds)
                            {
                                <tr>
                                    <td title="@h.SchemeName">@(h.SchemeName.Length > 20 ? h.SchemeName[..20] + "…" : h.SchemeName)</td>
                                    <td class="text-end">₹@h.CurrentValue.ToString("N0")</td>
                                    <td class="text-end @(h.ProfitLoss >= 0 ? "text-success" : "text-danger")">
                                        ₹@h.ProfitLoss.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <p class="text-muted p-3">No MF holdings. <a asp-controller="MutualFund" asp-action="Index">Upload now</a></p> }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between">
                <strong>US Stocks</strong>
                <a asp-controller="UsStock" asp-action="Index" class="btn btn-sm btn-outline-warning">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.TopUsStocks.Any())
                {
                    <table class="table table-sm table-striped mb-0">
                        <thead><tr><th>Symbol</th><th class="text-end">Value (INR)</th><th class="text-end">P&L</th></tr></thead>
                        <tbody>
                            @foreach (var h in Model.TopUsStocks)
                            {
                                <tr>
                                    <td>@h.Symbol</td>
                                    <td class="text-end">₹@h.CurrentValueInr.ToString("N0")</td>
                                    <td class="text-end @(h.ProfitLossInr >= 0 ? "text-success" : "text-danger")">
                                        ₹@h.ProfitLossInr.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <p class="text-muted p-3">No US stocks. <a asp-controller="UsStock" asp-action="Index">Add now</a></p> }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('allocationChart'), {
            type: 'doughnut',
            data: {
                labels: ['Equities', 'Mutual Funds', 'US Stocks', 'Cash'],
                datasets: [{
                    data: [@Model.EquityValue.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.MutualFundValue.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.UsStockValue.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.CashValue.ToString(System.Globalization.CultureInfo.InvariantCulture)],
                    backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#6c757d'],
                    borderWidth: 2
                }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });

        new Chart(document.getElementById('monthlyChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels)),
                datasets: [
                    {
                        label: 'Invested',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartInvestedValues)),
                        borderColor: '#0d6efd', backgroundColor: 'rgba(13,110,253,0.1)', fill: true, tension: 0.3
                    },
                    {
                        label: 'Current Value',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartCurrentValues)),
                        borderColor: '#198754', backgroundColor: 'rgba(25,135,84,0.1)', fill: true, tension: 0.3
                    }
                ]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true, ticks: { callback: v => '₹ ' + v.toLocaleString('en-IN') } } },
                plugins: { legend: { position: 'bottom' } }
            }
        });
    </script>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Portfolio Dashboard</h2>
    <form asp-controller="Dashboard" asp-action="RefreshPrices" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary">🔄 Refresh Prices</button>
    </form>
</div>
