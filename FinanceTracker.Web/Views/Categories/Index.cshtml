@model FinanceTracker.Web.Models.ViewModels.CategoryViewModel
@{
    ViewData["Title"] = "Manage Categories";
}

<h2 class="mb-4">📂 Manage Categories</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row">
    <!-- Add Category -->
    <div class="col-md-4 mb-4">
        <div class="card shadow">
            <div class="card-header"><strong>➕ Add Category</strong></div>
            <div class="card-body">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Category Name</label>
                        <input type="text" asp-for="NewCategory" class="form-control"
                               placeholder="e.g. Food, Travel, Utilities" />
                        <span asp-validation-for="NewCategory" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Add Category</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Category List -->
    <div class="col-md-8 mb-4">
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>All Categories (@Model.Categories.Count)</strong>
            </div>
            <div class="card-body">
                @if (Model.Categories.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var cat in Model.Categories)
                        {
                            <div class="d-flex align-items-center bg-light border rounded px-2 py-1">
                                <span class="badge bg-secondary me-2">@cat</span>
                                <form asp-action="Delete" method="post" class="d-inline m-0 p-0"
                                      onsubmit="return confirm('Remove category \'@cat\'?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="category" value="@cat" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Remove">✕</button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No categories yet. Add your first category above.</p>
                }
            </div>
        </div>
    </div>
</div>

<p class="text-muted small">
    Categories are auto-registered when you add or import expenses. Use this page to remove categories you no longer need.
    <a asp-controller="Expense" asp-action="Index">← Back to Expenses</a>
</p>
