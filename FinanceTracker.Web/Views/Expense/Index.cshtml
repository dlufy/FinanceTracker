@model FinanceTracker.Web.Models.ViewModels.ExpenseViewModel
@{
    ViewData["Title"] = "Expenses";
}

<h2 class="mb-4">💸 Expense Tracker</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ImportQueued"] != null)
{
    <div class="alert alert-info alert-dismissible fade show">⏳ @TempData["ImportQueued"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row mb-4">
    <!-- Manual Entry -->
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header"><strong>➕ Add Expense Manually</strong></div>
            <div class="card-body">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Date <span class="text-danger">*</span></label>
                        <input type="date" name="Date" value="@Model.Date.ToString("yyyy-MM-dd")" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount (₹) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input type="number" name="Amount" value="@(Model.Amount > 0 ? Model.Amount.ToString() : "")"
                                   class="form-control" step="0.01" min="0.01" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Category <span class="text-danger">*</span>
                            <small class="text-muted">— <a asp-controller="Categories" asp-action="Index" class="text-decoration-none">manage</a></small>
                        </label>
                        <input type="text" name="Category" id="categoryInput" value="@Model.Category" class="form-control"
                               placeholder="e.g., Food, Travel, Utilities..." required
                               autocomplete="off" />
                        <div id="categorySuggestions" class="list-group position-absolute shadow" style="z-index:100;display:none;"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text" name="Description" value="@Model.Description" class="form-control"
                               placeholder="Optional note..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Tags <small class="text-muted">(comma-separated) — <a asp-controller="Tags" asp-action="Index" class="text-decoration-none">manage tags</a></small>
                        </label>
                        <input type="text" name="TagsInput" id="tagsInput" value="@Model.TagsInput" class="form-control"
                               placeholder="e.g. work, personal, reimbursable"
                               autocomplete="off" />
                        <div id="tagSuggestions" class="list-group position-absolute shadow" style="z-index:100;display:none;"></div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Add Expense</button>
                </form>
            </div>
        </div>
    </div>

    <!-- CSV Upload -->
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header"><strong>📂 Upload Expenses (CSV / XLSX)</strong></div>
            <div class="card-body">
                <form asp-action="Preview" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Select file</label>
                        <input type="file" name="CsvFile" class="form-control" accept=".csv,.xlsx,.xls" required />
                    </div>
                    <button type="submit" class="btn btn-outline-primary w-100">📋 Upload &amp; Preview</button>
                </form>
                @if (Model.UploadMessage != null)
                {
                    <div class="alert @(Model.ShowPreview ? "alert-info" : "alert-warning") mt-3">@Model.UploadMessage</div>
                }
                <div class="accordion mt-3" id="expenseFormatAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#expenseFormat">
                                ℹ️ Expected CSV / XLSX Format
                            </button>
                        </h2>
                        <div id="expenseFormat" class="accordion-collapse collapse" data-bs-parent="#expenseFormatAccordion">
                            <div class="accordion-body small">
                                <strong>Required columns:</strong> Date, Amount, Category<br/>
                                <strong>Optional:</strong> Description, Tags (comma-separated within cell)<br/>
                                <hr class="my-2"/>
                                <code>Date,Amount,Category,Description,Tags</code><br/>
                                <code>2026-04-01,1500,Food,Lunch with team,"work,reimbursable"</code><br/>
                                <code>2026-04-02,500,Travel,Cab to office,personal</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Preview Section -->
@if (Model.ShowPreview && Model.PreviewExpenses.Any())
{
    <div class="card shadow mb-4 border-info">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <strong>📋 Preview — @Model.PreviewExpenses.Count expenses</strong>
            <div>
                @if (!string.IsNullOrEmpty(Model.PreviewFileId))
                {
                    <a asp-action="DownloadPreview" asp-route-id="@Model.PreviewFileId"
                       class="btn btn-outline-light btn-sm">📥 Download Preview CSV</a>
                }
                <form asp-action="ConfirmUpload" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm ms-2">✅ Confirm &amp; Import</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-light btn-sm ms-2">✕ Cancel</a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>#</th><th>Date</th><th>Amount</th><th>Category</th><th>Description</th><th>Tags</th></tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Math.Min(Model.PreviewExpenses.Count, 20); i++)
                        {
                            var e = Model.PreviewExpenses[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@e.Date.ToString("dd MMM yyyy")</td>
                                <td>₹ @e.Amount.ToString("N2")</td>
                                <td>@e.Category</td>
                                <td>@e.Description</td>
                                <td>@foreach (var t in e.Tags) { <span class="badge bg-info text-dark me-1">@t</span> }</td>
                            </tr>
                        }
                        @if (Model.PreviewExpenses.Count > 20)
                        {
                            <tr><td colspan="6" class="text-muted text-center small">... and @(Model.PreviewExpenses.Count - 20) more rows</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Filter Bar -->
<div class="card shadow mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>🔍 Filter Expenses</strong>
        <small><a asp-controller="Categories" asp-action="Index" class="text-decoration-none">📂 Manage categories</a></small>
    </div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">From</label>
                <input type="date" id="filterDateFrom" class="form-control form-control-sm" value="@Model.FilterDateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">To</label>
                <input type="date" id="filterDateTo" class="form-control form-control-sm" value="@Model.FilterDateTo" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Category</label>
                <select id="filterCategory" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.ExistingCategories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small">Tags</label>
                <select id="filterTags" class="form-select form-select-sm" multiple style="height:60px;">
                    @foreach (var tag in Model.AllTags)
                    {
                        <option value="@tag">@tag</option>
                    }
                </select>
                <small class="text-muted">Ctrl+click to select multiple</small>
            </div>
            <div class="col-md-2">
                <button id="applyFilter" class="btn btn-primary btn-sm w-100">Apply</button>
                <button id="resetFilter" class="btn btn-outline-secondary btn-sm w-100 mt-1">Reset</button>
            </div>
        </div>
    </div>
</div>

<!-- Summary + Chart -->
<div class="row mb-4" id="summaryRow" style="display:none!important;">
    <div class="col-md-4">
        <div class="card shadow h-100">
            <div class="card-header"><strong>Expenses by Category</strong></div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="expensePieChart" style="max-height:260px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="row g-3">
            <div class="col-6">
                <div class="card text-white bg-danger shadow">
                    <div class="card-body text-center">
                        <h6>Total (filtered)</h6>
                        <h4 id="statTotal">₹ 0.00</h4>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-white bg-secondary shadow">
                    <div class="card-body text-center">
                        <h6>Matching Expenses</h6>
                        <h4 id="statCount">0</h4>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-body p-2">
                        <table class="table table-sm mb-0" id="categoryBreakdown">
                            <thead><tr><th>Category</th><th class="text-end">Total</th></tr></thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Expense List -->
<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Expenses <span id="listCount" class="text-muted small"></span></strong>
        <form asp-action="DeleteAll" method="post" class="d-inline"
              onsubmit="return confirm('Delete ALL expenses?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">Clear All</button>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="p-2 border-bottom">
            <input type="text" id="expenseSearch" class="form-control form-control-sm"
                   placeholder="🔍 Quick search in results..." />
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 sortable-table" id="expenseTable">
                <thead class="table-dark">
                    <tr>
                        <th class="sortable" data-col="0">Date ↕</th>
                        <th class="sortable text-end" data-col="1">Amount ↕</th>
                        <th class="sortable" data-col="2">Category ↕</th>
                        <th>Description</th>
                        <th>Tags</th>
                        <th>Source</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="expenseTableBody">
                    <tr><td colspan="7" class="text-center text-muted p-3">Loading...</td></tr>
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center p-2 border-top" id="paginationBar">
            <div id="paginationInfo" class="text-muted small"></div>
            <nav>
                <ul class="pagination pagination-sm mb-0" id="paginationLinks"></ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    const defaultDateFrom = '@Model.FilterDateFrom';
    const defaultDateTo = '@Model.FilterDateTo';

    let currentPage = 1;
    let pieChart = null;
    const CHART_COLORS = ['#e74a3b','#f6c23e','#1cc88a','#4e73df','#36b9cc','#858796','#5a5c69','#fd7e14','#6f42c1','#20c997'];

    function getFilters() {
        const tags = Array.from(document.getElementById('filterTags').selectedOptions).map(o => o.value);
        return {
            dateFrom: document.getElementById('filterDateFrom').value || defaultDateFrom,
            dateTo: document.getElementById('filterDateTo').value || defaultDateTo,
            category: document.getElementById('filterCategory').value,
            tags: tags,
            page: currentPage,
            pageSize: 20
        };
    }

    function buildUrl(filters) {
        const p = new URLSearchParams();
        if (filters.dateFrom) p.set('dateFrom', filters.dateFrom);
        if (filters.dateTo) p.set('dateTo', filters.dateTo);
        if (filters.category) p.set('category', filters.category);
        filters.tags.forEach(t => p.append('tags', t));
        p.set('page', filters.page);
        p.set('pageSize', filters.pageSize);
        return '/Expense/List?' + p.toString();
    }

    async function loadExpenses() {
        const filters = getFilters();
        const url = buildUrl(filters);
        try {
            const resp = await fetch(url);
            const data = await resp.json();
            renderTable(data);
            renderChart(data.categoryTotals);
            renderPagination(data.page, data.totalPages, data.totalCount);
            renderSummary(data.totalAmount, data.totalCount, data.categoryTotals);
        } catch (e) {
            document.getElementById('expenseTableBody').innerHTML =
                '<tr><td colspan="7" class="text-danger text-center">Failed to load expenses.</td></tr>';
        }
    }

    function renderTable(data) {
        const tbody = document.getElementById('expenseTableBody');
        if (!data.items || data.items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-muted text-center p-3">No expenses match the current filter.</td></tr>';
            return;
        }
        tbody.innerHTML = data.items.map((e, idx) => {
            const tags = (e.tags || []).map(t => `<span class="badge bg-info text-dark me-1">${t}</span>`).join('');
            const plSign = e.amount >= 0 ? '' : '-';
            const amtFmt = Math.abs(e.amount).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            const dateStr = new Date(e.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
            return `<tr data-tags="${(e.tags||[]).join(' ').toLowerCase()}">
                <td>${dateStr}</td>
                <td class="text-end">₹ ${amtFmt}</td>
                <td><span class="badge bg-secondary">${escHtml(e.category)}</span></td>
                <td>${escHtml(e.description || '')}</td>
                <td>${tags}</td>
                <td><small class="text-muted">${escHtml(e.source||'')}</small></td>
                <td>
                    <form method="post" action="/Expense/Delete" class="d-inline" onsubmit="return confirm('Remove this expense?')">
                        <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                        <input type="hidden" name="id" value="${e.id}" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                    </form>
                </td>
            </tr>`;
        }).join('');

        setupSortFilter('expenseTable', 'expenseSearch');
    }

    function renderPagination(page, totalPages, totalCount) {
        document.getElementById('paginationInfo').textContent =
            totalCount > 0 ? `Page ${page} of ${totalPages} (${totalCount} total)` : '';
        document.getElementById('listCount').textContent = totalCount > 0 ? `(${totalCount})` : '';

        const ul = document.getElementById('paginationLinks');
        ul.innerHTML = '';
        if (totalPages <= 1) return;

        const addPage = (label, p, disabled) => {
            const li = document.createElement('li');
            li.className = 'page-item' + (disabled ? ' disabled' : '') + (p === page ? ' active' : '');
            const a = document.createElement('a');
            a.className = 'page-link';
            a.href = '#';
            a.textContent = label;
            if (!disabled) a.addEventListener('click', ev => { ev.preventDefault(); currentPage = p; loadExpenses(); });
            li.appendChild(a);
            ul.appendChild(li);
        };

        addPage('‹', page - 1, page === 1);
        const start = Math.max(1, page - 2), end = Math.min(totalPages, page + 2);
        for (let p = start; p <= end; p++) addPage(p, p, false);
        addPage('›', page + 1, page === totalPages);
    }

    function renderChart(categoryTotals) {
        const entries = Object.entries(categoryTotals || {}).sort((a, b) => b[1] - a[1]);
        const summaryRow = document.getElementById('summaryRow');
        if (entries.length === 0) {
            summaryRow.style.setProperty('display', 'none', 'important');
            if (pieChart) { pieChart.destroy(); pieChart = null; }
            return;
        }
        summaryRow.style.removeProperty('display');

        const labels = entries.map(e => e[0]);
        const values = entries.map(e => e[1]);
        const colors = labels.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]);

        if (pieChart) {
            pieChart.data.labels = labels;
            pieChart.data.datasets[0].data = values;
            pieChart.data.datasets[0].backgroundColor = colors;
            pieChart.update();
        } else {
            pieChart = new Chart(document.getElementById('expensePieChart'), {
                type: 'doughnut',
                data: { labels, datasets: [{ data: values, backgroundColor: colors }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        }
    }

    function renderSummary(totalAmount, totalCount, categoryTotals) {
        document.getElementById('statTotal').textContent =
            '₹ ' + totalAmount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        document.getElementById('statCount').textContent = totalCount;

        const tbody = document.querySelector('#categoryBreakdown tbody');
        const entries = Object.entries(categoryTotals || {}).sort((a, b) => b[1] - a[1]);
        tbody.innerHTML = entries.map(([cat, amt]) =>
            `<tr><td>${escHtml(cat)}</td><td class="text-end">₹ ${amt.toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td></tr>`
        ).join('');
    }

    function escHtml(str) {
        return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    // Category autocomplete
    const categoryInput = document.getElementById('categoryInput');
    const catSugg = document.getElementById('categorySuggestions');
    if (categoryInput && catSugg) {
        categoryInput.addEventListener('input', async function () {
            const q = this.value.trim();
            if (!q) { catSugg.style.display = 'none'; return; }
            const resp = await fetch('/Expense/CategorySuggestions?q=' + encodeURIComponent(q));
            const suggestions = await resp.json();
            if (!suggestions.length) { catSugg.style.display = 'none'; return; }
            catSugg.innerHTML = suggestions.map(c =>
                `<button type="button" class="list-group-item list-group-item-action py-1 px-2 small">${escHtml(c)}</button>`
            ).join('');
            catSugg.style.display = 'block';
            catSugg.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', () => {
                    categoryInput.value = btn.textContent;
                    catSugg.style.display = 'none';
                    categoryInput.focus();
                });
            });
        });
        document.addEventListener('click', e => { if (!catSugg.contains(e.target)) catSugg.style.display = 'none'; });
    }

    // Tag autocomplete
    const tagsInput = document.getElementById('tagsInput');
    const tagSugg = document.getElementById('tagSuggestions');
    if (tagsInput && tagSugg) {
        tagsInput.addEventListener('input', async function () {
            const parts = this.value.split(/[,;]/);
            const last = parts[parts.length - 1].trim();
            if (!last) { tagSugg.style.display = 'none'; return; }
            const resp = await fetch('/Expense/TagSuggestions?q=' + encodeURIComponent(last));
            const suggestions = await resp.json();
            if (!suggestions.length) { tagSugg.style.display = 'none'; return; }
            tagSugg.innerHTML = suggestions.map(t =>
                `<button type="button" class="list-group-item list-group-item-action py-1 px-2 small">${escHtml(t)}</button>`
            ).join('');
            tagSugg.style.display = 'block';
            tagSugg.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', () => {
                    const parts2 = tagsInput.value.split(/[,;]/);
                    parts2[parts2.length - 1] = btn.textContent;
                    tagsInput.value = parts2.join(', ') + ', ';
                    tagSugg.style.display = 'none';
                    tagsInput.focus();
                });
            });
        });
        document.addEventListener('click', e => { if (!tagSugg.contains(e.target)) tagSugg.style.display = 'none'; });
    }

    // Filter buttons
    document.getElementById('applyFilter').addEventListener('click', () => { currentPage = 1; loadExpenses(); });
    document.getElementById('resetFilter').addEventListener('click', () => {
        document.getElementById('filterDateFrom').value = defaultDateFrom;
        document.getElementById('filterDateTo').value = defaultDateTo;
        document.getElementById('filterCategory').value = '';
        Array.from(document.getElementById('filterTags').options).forEach(o => o.selected = false);
        currentPage = 1;
        loadExpenses();
    });
    document.getElementById('expenseSearch').addEventListener('input', function () {
        const term = this.value.toLowerCase();
        document.querySelectorAll('#expenseTableBody tr').forEach(row => {
            row.style.display = !term || row.innerText.toLowerCase().includes(term) ? '' : 'none';
        });
    });

    // Refresh category dropdown via AJAX so async imports are reflected without a page reload
    async function refreshCategories() {
        try {
            const resp = await fetch('/Expense/Categories');
            const cats = await resp.json();
            const sel = document.getElementById('filterCategory');
            const current = sel.value;
            sel.innerHTML = '<option value="">All Categories</option>' +
                cats.map(c => `<option value="${escHtml(c)}">${escHtml(c)}</option>`).join('');
            // Restore selection if it still exists
            if (cats.includes(current)) sel.value = current;
        } catch { /* non-critical */ }
    }

    // Initial load
    refreshCategories();
    loadExpenses();
})();
</script>
}
