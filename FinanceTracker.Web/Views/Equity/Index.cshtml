@model FinanceTracker.Web.Models.ViewModels.EquityUploadViewModel
@{
    ViewData["Title"] = "Equity Holdings";
}

<h2 class="mb-4">📈 Equity Holdings</h2>

<!-- Upload Section -->
<div class="card shadow mb-4">
    <div class="card-header"><strong>Upload Equity Holdings (CSV or XLSX)</strong></div>
    <div class="card-body">
        <form asp-action="Preview" method="post" enctype="multipart/form-data">
            <div class="row align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Account / Broker <span class="text-danger">*</span></label>
                    <input type="text" name="AccountTag" value="@Model.AccountTag" class="form-control"
                           placeholder="e.g., Zerodha, Groww" required
                           list="existingAccounts" />
                    <datalist id="existingAccounts">
                        @foreach (var acct in Model.ExistingAccounts)
                        {
                            <option value="@acct" />
                        }
                    </datalist>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Select your holdings file</label>
                    <input type="file" name="CsvFile" class="form-control" accept=".csv,.xlsx,.xls" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 mt-2">📋 Upload &amp; Preview</button>
                </div>
            </div>
            <small class="text-muted mt-1 d-block">
                Re-uploading for the same account will <strong>replace</strong> all existing holdings for that account.
            </small>
        </form>

        @if (Model.UploadMessage != null)
        {
            <div class="alert @(Model.ShowPreview ? "alert-info" : "alert-warning") mt-3">@Model.UploadMessage</div>
        }

        <!-- Format Info Accordion -->
        <div class="accordion mt-3" id="formatInfoAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#formatInfo">
                        ℹ️ Expected File Formats (click to expand)
                    </button>
                </h2>
                <div id="formatInfo" class="accordion-collapse collapse" data-bs-parent="#formatInfoAccordion">
                    <div class="accordion-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6><strong>CSV Format</strong></h6>
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light"><tr><th>Column</th><th>Example</th></tr></thead>
                                    <tbody>
                                        <tr><td>Symbol <span class="text-danger">*</span></td><td>RELIANCE</td></tr>
                                        <tr><td>Company Name</td><td>Reliance Industries Ltd</td></tr>
                                        <tr><td>Quantity <span class="text-danger">*</span></td><td>10</td></tr>
                                        <tr><td>Average Price <span class="text-danger">*</span></td><td>2500.00</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h6><strong>XLSX Format (Groww / Broker Export)</strong></h6>
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light"><tr><th>Column</th><th>Example</th></tr></thead>
                                    <tbody>
                                        <tr><td>Stock Name <span class="text-danger">*</span></td><td>RELIANCE INDUSTRIES</td></tr>
                                        <tr><td>Symbol <span class="text-danger">*</span></td><td>RELIANCE</td></tr>
                                        <tr><td>ISIN</td><td>INE002A01018</td></tr>
                                        <tr><td>Quantity <span class="text-danger">*</span></td><td>10</td></tr>
                                        <tr><td>Average buy price <span class="text-danger">*</span></td><td>2500.00</td></tr>
                                        <tr><td>Closing price</td><td>2650.00</td></tr>
                                    </tbody>
                                </table>
                                <small class="text-muted"><span class="text-danger">*</span> Required. Use the NSE/BSE ticker code in the Symbol column (e.g., RELIANCE, INFY, HDFCBANK).</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Preview Section -->
@if (Model.ShowPreview && Model.PreviewHoldings.Any())
{
    <div class="card shadow mb-4 border-info">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <strong>📋 Preview — @Model.PreviewHoldings.Count holdings for "@Model.PreviewAccountTag"</strong>
            <div>
                @if (!string.IsNullOrEmpty(Model.PreviewFileId))
                {
                    <a asp-action="DownloadPreview" asp-route-id="@Model.PreviewFileId"
                       class="btn btn-outline-light btn-sm">📥 Download Preview CSV</a>
                }
                <form asp-action="ConfirmUpload" method="post" class="d-inline" id="confirmForm">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm ms-2" id="confirmBtn">
                        ✅ Confirm &amp; Save
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-light btn-sm ms-2">✕ Cancel</a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Name / Symbol</th>
                            <th>ISIN</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Avg Buy Price</th>
                            <th class="text-end">Current Price</th>
                            <th class="text-end">Invested Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.PreviewHoldings.Count; i++)
                        {
                            var h = Model.PreviewHoldings[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>
                                    <strong>@h.CompanyName</strong><br/>
                                    <small class="text-muted">@h.Symbol</small>
                                </td>
                                <td><small>@h.Isin</small></td>
                                <td class="text-end">@h.Quantity</td>
                                <td class="text-end">₹ @h.AverageBuyPrice.ToString("N2")</td>
                                <td class="text-end">₹ @h.CurrentPrice.ToString("N2")</td>
                                <td class="text-end">₹ @h.InvestedValue.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end"><strong>Total</strong></td>
                            <td class="text-end"><strong>@Model.PreviewHoldings.Sum(h => h.Quantity)</strong></td>
                            <td></td>
                            <td></td>
                            <td class="text-end"><strong>₹ @Model.PreviewHoldings.Sum(h => h.InvestedValue).ToString("N2")</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

<!-- Holdings Table -->
<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Current Holdings (@Model.Holdings.Count)</strong>
        @if (Model.Holdings.Any())
        {
            <form asp-action="DeleteAll" method="post" class="d-inline"
                  onsubmit="return confirm('Delete ALL equity holdings from ALL accounts?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger">Clear All</button>
            </form>
        }
    </div>
    <div class="card-body p-0">
        @if (Model.Holdings.Any())
        {
            @if (Model.ExistingAccounts.Any())
            {
                <div class="p-2 bg-light border-bottom">
                    <small class="text-muted me-2">Accounts:</small>
                    @foreach (var acct in Model.ExistingAccounts)
                    {
                        var acctCount = Model.Holdings.Count(h => h.AccountTag.Equals(acct, StringComparison.OrdinalIgnoreCase));
                        <span class="badge bg-secondary me-1">@acct (@acctCount)</span>
                        <form asp-action="DeleteAccount" method="post" class="d-inline"
                              onsubmit="return confirm('Delete all holdings from @acct?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="accountTag" value="@acct" />
                            <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1 me-2" title="Delete all @acct holdings">✕</button>
                        </form>
                    }
                </div>
            }

            <!-- Pie Chart by Account -->
            <div class="row g-0">
                <div class="col-md-4 p-3 border-end">
                    <h6 class="text-center text-muted">Allocation by Account</h6>
                    <canvas id="equityPieChart" height="200"></canvas>
                </div>
                <div class="col-md-8">
                    <div class="p-2 border-bottom">
                        <input type="text" id="equitySearch" class="form-control form-control-sm" placeholder="🔍 Search holdings..." />
                    </div>
                    <div class="table-responsive">
                        <table id="equityTable" class="table table-striped table-hover mb-0 sortable-table">
                            <thead class="table-dark">
                                <tr>
                                    <th class="sortable" data-col="0">Account ↕</th>
                                    <th class="sortable" data-col="1">Symbol / Name ↕</th>
                                    <th class="text-end sortable" data-col="2">Qty ↕</th>
                                    <th class="text-end sortable" data-col="3">Avg Price ↕</th>
                                    <th class="text-end sortable" data-col="4">Curr Price ↕</th>
                                    <th class="text-end sortable" data-col="5">Invested ↕</th>
                                    <th class="text-end sortable" data-col="6">Value ↕</th>
                                    <th class="text-end sortable" data-col="7">P&amp;L ↕</th>
                                    <th class="text-end sortable" data-col="8">P&amp;L% ↕</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in Model.Holdings.OrderBy(h => h.AccountTag).ThenBy(h => h.Symbol))
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@h.AccountTag</span></td>
                                        <td>
                                            <strong>@h.Symbol</strong>
                                            @if (h.CompanyName != h.Symbol)
                                            {
                                                <br/><small class="text-muted">@h.CompanyName</small>
                                            }
                                        </td>
                                        <td class="text-end">@h.Quantity</td>
                                        <td class="text-end">₹ @h.AverageBuyPrice.ToString("N2")</td>
                                        <td class="text-end">₹ @h.CurrentPrice.ToString("N2")</td>
                                        <td class="text-end">₹ @h.InvestedValue.ToString("N2")</td>
                                        <td class="text-end">₹ @h.CurrentValue.ToString("N2")</td>
                                        <td class="text-end @(h.ProfitLoss >= 0 ? "text-success" : "text-danger")">
                                            ₹ @h.ProfitLoss.ToString("N2")
                                        </td>
                                        <td class="text-end @(h.ProfitLossPercent >= 0 ? "text-success" : "text-danger")">
                                            @h.ProfitLossPercent.ToString("N2")%
                                        </td>
                                        <td>
                                            <form asp-action="Delete" method="post" class="d-inline"
                                                  onsubmit="return confirm('Remove this holding?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@h.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td class="text-end" colspan="2"><strong>Total</strong></td>
                                    <td></td><td></td><td></td>
                                    <td class="text-end"><strong>₹ @Model.Holdings.Sum(h => h.InvestedValue).ToString("N2")</strong></td>
                                    <td class="text-end"><strong>₹ @Model.Holdings.Sum(h => h.CurrentValue).ToString("N2")</strong></td>
                                    <td class="text-end @(Model.Holdings.Sum(h => h.ProfitLoss) >= 0 ? "text-success" : "text-danger")">
                                        <strong>₹ @Model.Holdings.Sum(h => h.ProfitLoss).ToString("N2")</strong>
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center text-muted p-4">
                <p>No equity holdings yet. Upload a CSV or XLSX file to get started.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        setupSortFilter('equityTable', 'equitySearch');

        @if (Model.Holdings.Any())
        {
            var accountGroups = Model.Holdings
                .GroupBy(h => h.AccountTag)
                .Select(g => new { Label = g.Key, Value = g.Sum(h => h.CurrentValue) })
                .ToList();
            <text>
            new Chart(document.getElementById('equityPieChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(accountGroups.Select(g => g.Label))),
                    datasets: [{ data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(accountGroups.Select(g => g.Value))),
                        backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#6c757d','#0dcaf0'] }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            </text>
        }
    </script>
}
